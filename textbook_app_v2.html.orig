    <tr><td>1</td><td>手札 = [5, 5, 10]</td><td>ペア（5を2枚）で出す</td></tr>
    <tr><td>2</td><td>手札 = [3, 7, 10]</td><td>シングル（3を1枚）で出す</td></tr>
    <tr><td>3</td><td>手札 = [13, 13]</td><td>ペア（13を2枚）で出す</td></tr>
  </table>

